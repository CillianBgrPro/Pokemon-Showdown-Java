<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="600.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.pokemon.controller.HomeController">

    <ImageView fitHeight="600.0" fitWidth="800.0" pickOnBounds="true">
        <image>
            <Image url="@pictures/home_background.png" />
        </image>
    </ImageView>

    <Button fx:id="btnCreateTeam" onAction="#handleStart"
            layoutX="280.0" layoutY="218.0"
            prefWidth="250.0" prefHeight="80.0"
            style="-fx-background-color: transparent; -fx-cursor: hand; -fx-border-color: transparent;">
    </Button>

</AnchorPane>